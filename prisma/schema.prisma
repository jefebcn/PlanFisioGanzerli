generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SECRETARY
  THERAPIST
}

enum ResourceType {
  TECAR
  LASER
  VISS
  ROOM
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OverrideReason {
  EMERGENCY
  SUBSTITUTE_DEVICE
  MANAGER_DECISION
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         UserRole
  color        String   @default("#3b82f6")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointmentsAsTherapist Appointment[]       @relation("AppointmentTherapist")
  appointmentsCreated     Appointment[]       @relation("AppointmentCreatedBy")
  overridesApproved       ConflictOverride[]  @relation("OverrideApprovedBy")
}

model Patient {
  id           String        @id @default(cuid())
  fullName     String
  phone        String?
  email        String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model Resource {
  id        String            @id @default(cuid())
  name      String
  type      ResourceType
  quantity  Int               @default(1)
  active    Boolean           @default(true)
  bookings  ResourceBooking[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Therapy {
  id                    String         @id @default(cuid())
  name                  String
  durationMinutes       Int
  requiredResourceTypes ResourceType[]
  appointments          Appointment[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model Appointment {
  id          String            @id @default(cuid())
  therapistId String
  patientId   String
  therapyId   String
  startsAt    DateTime
  endsAt      DateTime
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?
  createdById String
  version     Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  therapist        User              @relation("AppointmentTherapist", fields: [therapistId], references: [id])
  patient          Patient           @relation(fields: [patientId], references: [id])
  therapy          Therapy           @relation(fields: [therapyId], references: [id])
  createdBy        User              @relation("AppointmentCreatedBy", fields: [createdById], references: [id])
  resourceBookings ResourceBooking[]
  override         ConflictOverride?

  @@index([therapistId, startsAt, endsAt])
  @@index([patientId, startsAt, endsAt])
  @@index([startsAt, endsAt])
}

model ResourceBooking {
  id            String   @id @default(cuid())
  appointmentId String
  resourceId    String
  startsAt      DateTime
  endsAt        DateTime

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceId], references: [id])

  @@index([resourceId, startsAt, endsAt])
  @@index([appointmentId])
}

model ConflictOverride {
  id            String         @id @default(cuid())
  appointmentId String         @unique
  reason        OverrideReason
  note          String
  approvedById  String
  createdAt     DateTime       @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  approvedBy  User        @relation("OverrideApprovedBy", fields: [approvedById], references: [id])
}
